@page "/"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Sentinel.Web.Components.Shared
@inject AppDbContext Db

<PageTitle>Sentinel — Dashboard</PageTitle>

<div class="space-y-6">

    <PageHeader Title="Dashboard"/>

    <div class="grid grid-cols-3 gap-4">

        <StatCard Label="Active Incidents" Value="@_incidentCount.ToString()" Color="text-ctp-red" />
        <StatCard Label="Runbooks"         Value="@_runbookCount.ToString()" Color="text-ctp-blue" />
        <StatCard Label="Knowledge Base"   Value="@_knowledgeCount.ToString()" Color="text-ctp-teal" />

    </div>


    <div class="bg-ctp-mantle border border-ctp-surface rounded-lg p-4">
        <p class="text-ctp-subtle text-sm font-semibold mb-3">Recent Activity</p>
        <p class="text-ctp-muted text-sm">No recent activity.</p>
    </div>

</div>

@code
{
    private int _incidentCount;
    private int _runbookCount;
    private int _knowledgeCount;

    protected override async Task OnInitializedAsync()
    {
        _incidentCount = await Db.Incidents.CountAsync();
        _runbookCount = await Db.Runbooks.CountAsync();
        _knowledgeCount = await Db.KnowledgeEntries.CountAsync();
    }
}
